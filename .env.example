# Last.fm API Key (required for artist bios, similar artists, and listener stats)
# Get a free API key at: https://www.last.fm/api/account/create
NEXT_PUBLIC_LASTFM_API_KEY=your_lastfm_api_key_here

# Spotify API Credentials (required for Spotify artist/album/track data)
# Create an app at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# YouTube Data API Key (required for music video search)
# Get an API key at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here
